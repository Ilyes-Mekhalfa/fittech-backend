  fitapi_membresubscription fitapi_membresubscription? @relation(fields: [subscription_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fitapi_payment_subscription_id_9145130d_fk_fitapi_me")

  @@index([invoice_number], map: "fitapi_payment_invoice_number_3c3bc9a1_like")
  @@index([membre_id], map: "fitapi_payment_membre_id_911708bb")
  @@index([subscription_id], map: "fitapi_payment_subscription_id_9145130d")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model fitapi_subscriptionplan {
  id                        String                      @id @db.Uuid
  name                      String                      @db.VarChar(100)
  type                      String                      @db.VarChar(20)
  price                     Decimal                     @db.Decimal(10, 2)
  sessions_count            Int
  duration_days             Int
  auto_renew                Boolean
  created_at                DateTime                    @db.Timestamptz(6)
  fitapi_membresubscription fitapi_membresubscription[]
}

model fitapi_user {
  password                         String                             @db.VarChar(128)
  last_login                       DateTime?                          @db.Timestamptz(6)
  id                               String                             @id @db.Uuid
  first_name                       String                             @db.VarChar(100)
  last_name                        String                             @db.VarChar(100)
  email                            String                             @unique @db.VarChar(254)
  phone                            String?                            @db.VarChar(20)
  role                             String                             @db.VarChar(20)
  profile_photo                    String?                            @db.VarChar(100)
  created_at                       DateTime                           @db.Timestamptz(6)
  is_active                        Boolean
  archived_at                      DateTime?
  django_admin_log                 django_admin_log[]
  fitapi_coach                     fitapi_coach?
  fitapi_membre                    fitapi_membre?
  fitapi_user_groups               fitapi_user_groups[]
  fitapi_user_user_permissions     fitapi_user_user_permissions[]
  token_blacklist_outstandingtoken token_blacklist_outstandingtoken[]

  @@index([email], map: "fitapi_user_email_9df7fa75_like")
}

