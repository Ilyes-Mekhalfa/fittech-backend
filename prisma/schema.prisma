  join_date                 DateTime                    @db.Date
  user_id                   String                      @unique @db.Uuid
  fitapi_user               fitapi_user                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fitapi_membre_user_id_400a03a2_fk_fitapi_user_id")
