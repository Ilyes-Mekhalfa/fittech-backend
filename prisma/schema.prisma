
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  ADMIN
  COACH
  MEMBER
  MANAGER
}
model AnnexManager {
  id         Int      @id @default(autoincrement())
  annexName  String   @default("annex")
  annexCode  String   @unique
  role       ROLE     @default(MANAGER)
  email      String   @unique
  password   String
  createdAt  DateTime @default(now())
  address    String
  phone      String

 // coaches       Coach[]
 // members       Member[]
}

